---
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/sidebar";
import { getCollection } from "astro:content";
import { buildSidebar } from "@/utils/sidebar";

type Props = CollectionEntry<"docs">["data"];

const rawPosts = await getCollection("docs");
const groupedItems = buildSidebar(rawPosts);

const { title, description, published, updated, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        display: grid;
        grid-template-columns: 240px 1fr;
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
        padding-block: 0;
      }

      .sticky {
        position: sticky;
        top: 0;
        height: 100dvh;
        overflow-y: scroll;
        /*overscroll-behavior-block: contain;*/
        padding-block: 1.5rem;
      }

      .prose {
        margin: auto;
        padding-block: 1.5rem;
        color: rgb(var(--gray-dark));

        p {
          max-width: 64ch;
          text-wrap: pretty;
        }
      }
      .title {
        margin-bottom: 1em;
        padding: 0;
        /*text-align: center;*/
        line-height: 1;
      }
      .title h1 {
        margin: 0 0 0.5em 0;
      }
      .date {
        margin-bottom: 0.5em;
        color: rgb(var(--gray));
      }
      .last-updated-on {
        font-style: italic;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <aside class="sidebar">
        <div class="sticky"><Sidebar tree={groupedItems} client:load /></div>
      </aside>
      <article>
        <div class="prose">
          <div class="title">
            <h1>{title}</h1>
            <div class="date">
              Last updated: <FormattedDate date={updated ?? published} />
            </div>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
