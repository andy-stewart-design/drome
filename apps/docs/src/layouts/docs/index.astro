---
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/sidebar";
import TableOfContents from "@/components/table-of-contents";
import TableOfContentsMobile from "@/components/table-of-contents-mobile";
import { getCollection } from "astro:content";
import { buildSidebar } from "@/utils/sidebar";
import s from "./style.module.css";

type Props = CollectionEntry<"docs">["data"] & { headings?: MarkdownHeading[] };

const rawPosts = await getCollection("docs");
const groupedItems = buildSidebar(
  rawPosts.filter((p) => p.data.published !== false),
);

const { title, description, created, updated, headings = [] } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title ?? ""} description={description ?? ""} />
  </head>

  <body>
    <Header />
    <main class={s.main}>
      <aside class={s.sidebar}>
        <div class={s.sticky}>
          <Sidebar
            tree={groupedItems}
            currentPath={Astro.url.pathname}
            client:load
          />
        </div>
      </aside>
      <article class={s.article}>
        <TableOfContentsMobile headings={headings} client:load />
        <div class={s.prose}>
          <div class={s.title}>
            <h1>{title}</h1>
            <div class={s.date}>
              Last updated: <FormattedDate date={updated ?? created!} />
            </div>
          </div>
          <slot />
        </div>
      </article>
      <aside class={s.toc}>
        <div class={s.sticky}>
          <TableOfContents headings={headings} client:load />
        </div>
      </aside>
    </main>
    <Footer />
  </body>
</html>
