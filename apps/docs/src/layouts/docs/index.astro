---
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/sidebar";
import { getCollection } from "astro:content";
import { buildSidebar } from "@/utils/sidebar";
import s from "./style.module.css";

type Props = CollectionEntry<"docs">["data"];

const rawPosts = await getCollection("docs");
const groupedItems = buildSidebar(rawPosts);

const { title, description, published, updated } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />
    <main class={s.main}>
      <aside class={s.sidebar}>
        <div class={s.sticky}>
          <Sidebar
            tree={groupedItems}
            currentPath={Astro.url.pathname}
            client:load
          />
        </div>
      </aside>
      <article>
        <div class={s.prose}>
          <div class={s.title}>
            <h1>{title}</h1>
            <div class={s.date}>
              Last updated: <FormattedDate date={updated ?? published} />
            </div>
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
